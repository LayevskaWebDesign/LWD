# Bundle de skills (local, no se versiona)
skills-bundle/

# Dependencias
node_modules/
.pnp
.pnp.js
.yarn/

# Builds / salidas de compilación (Vite, React)
dist/
build/
.vite/
*.local

# Variables de entorno y secretos
.env
.env.*
!.env.example
*.pem

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cachés de herramientas
.cache/
.temp/
.tmp/
.eslintcache
.parcel-cache/

# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Editores / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Copias de seguridad locales
*.bak
*~
